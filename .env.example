### 企业微信(WeCom)基础
WECOM_CORP_ID=wwxxxxxxxxxxxxxxxx
WECOM_CORP_SECRET=replace_me
WECOM_AGENT_ID=1000002

### 企业微信回调（安全模式）
WECOM_TOKEN=replace_me
WECOM_ENCODING_AES_KEY=replace_me_43_chars

### DeepSeek（OpenAI-compatible）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=replace_me
DEEPSEEK_CHAT_MODEL=deepseek-chat

### RAG/向量库
CHROMA_PERSIST_DIR=./data/chroma
RAG_TOP_K=4
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=120

### 记忆
MEMORY_MAX_TURNS=8

### 管理后台（简单）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_me_strong

### 微信小程序（小程序 wx.login -> jscode2session）
# 须与微信开发者工具里的 AppID 一致；改完后务必重启后端进程
WX_MINI_APPID=
WX_MINI_SECRET=
# 部署自检（浏览器/curl）：GET https://你的域名/api/mini-status
# 应返回 wx_mini_configured: true 且 appid 与小程序一致

### 运行
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
